{
  "name": "@detama/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev -H 0.0.0.0",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:parent": "vite build -c vite.parent.config.ts",
    "build:checkout": "vite build -c vite.checkout.config.ts",
    "build:all": "npm run build:parent && npm run build:checkout && npm run build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@detama/shared": "*",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  }
}
