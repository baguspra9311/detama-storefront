---
/**
 * FullPageLayout — Standard full HTML page.
 *
 * Use this for standalone pages like the Checkout Iframe
 * that load as their own document (not fragments).
 */
export interface Props {
  title: string;
  description?: string;
  /** Additional CSS URLs */
  stylesheets?: string[];
  /** Additional JS URLs */
  scripts?: string[];
}

const {
  title,
  description = 'DeTama Checkout',
  stylesheets = [],
  scripts = [],
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {stylesheets.map((href) => <link rel="stylesheet" href={href} />)}
  </head>
  <body>
    <slot />

    {scripts.map((src) => <script defer src={src}></script>)}
  </body>
</html>
