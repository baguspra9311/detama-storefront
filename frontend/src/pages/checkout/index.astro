---
import FullPageLayout from '../../layouts/FullPageLayout.astro';
import '../../styles/checkout-parent.css';
---

<FullPageLayout title="Checkout | Detama Storefront" description="Selesaikan pesanan Anda">
  
  <div class="checkout-wrapper">
    
    <!-- CS Banner (Hidden by Default) -->
    <div id="cs-mode-banner">
      <p>⚠️ Keranjang Anda tidak valid atau kedaluwarsa.</p>
      <a href="https://wa.me/message/YOUR_CS_NUMBER" target="_blank" style="color: inherit; text-decoration: underline;">Hubungi Layanan Pelanggan kami (WhatsApp)</a>
    </div>

    <!-- Main Content: Forms & Iframe -->
    <div class="checkout-main">
      <!-- Loading Skeleton -->
      <div id="iframe-loading">
        <div class="spinner"></div>
      </div>
      
      <!-- Target for Iframe injected by IframeManager -->
      <div id="iframe-wrapper" style="width: 100%; height: 100%; min-height: 800px;"></div>
    </div>

    <!-- Sidebar: Cart & Totals -->
    <div class="checkout-sidebar">
      
      <!-- Cart Items -->
      <div>
        <h3 style="margin-top: 0; margin-bottom: 16px;">Ringkasan Belanja</h3>
        <div id="cart-items-container">
          <p class="text-sm" style="color: #777;">Memuat detail produk...</p>
        </div>
      </div>

      <!-- Voucher input -->
      <div class="voucher-form">
        <input type="text" id="voucher-input" placeholder="Kode Diskon (Opsional)" />
        <button id="apply-voucher-btn">Gunakan</button>
      </div>

      <hr style="border: none; border-top: 1px solid #e8e8e8; margin: 4px 0;" />

      <!-- Payment Method Selection -->
      <div>
        <h3 style="margin-top: 0; margin-bottom: 12px; font-size: 16px;">Metode Pembayaran</h3>
        <button id="select-payment-btn" class="payment-selection-trigger">
          Memuat metode pembayaran...
        </button>
      </div>

      <!-- Totals Breakdown -->
      <div id="totals-container"></div>
      
    </div>
  </div>

  <!-- Sticky Footer -->
  <div class="checkout-footer">
    <div>
      <div style="font-size: 12px; color: #777; margin-bottom: 4px;">Total Tagihan</div>
      <div id="sticky-total-price" class="checkout-footer-total">
        <span id="footer-total-skeleton">Rp -</span>
      </div>
    </div>
    <button id="submit-checkout-btn" class="checkout-footer-btn" disabled>
      Selesaikan Pesanan
    </button>
  </div>

  <!-- Payment Modal -->
  <div id="payment-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="modal-close" data-close-modal>&times;</button>
      <h2 style="margin-top: 0; margin-bottom: 20px; font-size: 20px;">Pilih Pembayaran</h2>
      <div id="payment-methods-grid">
        <div style="text-align: center; padding: 20px;"><div class="spinner" style="margin: 0 auto;"></div></div>
      </div>
    </div>
  </div>

  <!-- Build checkout parent script using Vite -->
  <script src="/checkout-parent-bundle.js" is:inline></script>
</FullPageLayout>
