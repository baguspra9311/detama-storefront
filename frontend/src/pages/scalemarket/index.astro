---
import FragmentLayout from '../../layouts/FragmentLayout.astro';
import fs from 'fs';
import path from 'path';

// Read the cleaned ScaleMarket HTML (just the .scalemarket-wrapper content)
const htmlPath = path.join(process.cwd(), 'public/scalemarket/content_only.html');
let rawHtml = '';
try {
  rawHtml = fs.readFileSync(htmlPath, 'utf-8');
} catch (e) {
  console.error('Error reading ScaleMarket HTML fragment:', e);
}
---

<FragmentLayout
  stylesheetUrl="/css/scalemarket.css"
  scriptUrl="/js/scalemarket-app.js"
>
  <link rel="stylesheet" href="/css/scalemarket-inline.css" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet" />
  <div set:html={rawHtml} />
</FragmentLayout>
