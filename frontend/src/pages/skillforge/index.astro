---
/**
 * SkillForge Landing Page Fragment
 * Outputs a bare HTML fragment for Scalev injection.
 */
import FragmentLayout from '../../layouts/FragmentLayout.astro';
---

<FragmentLayout
  stylesheetUrl="/css/skillforge.css"
  scriptUrl="/js/skillforge-app.js"
>
<div id="skillforge-app">
<header class="sf-header">
<div class="sf-container sf-nav">
<a class="sf-logo" href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">
<svg fill="none" height="32" viewBox="0 0 40 40" width="32" xmlns="http://www.w3.org/2000/svg">
<rect fill="#0F172A" height="40" rx="8" width="40"></rect>
<rect fill="#D97706" height="2" width="24" x="8" y="30"></rect>
<path d="M12 12V26M28 12V26M12 12H28M12 18H28M20 12V26" stroke="white" stroke-linecap="round" stroke-width="2.5"></path>
</svg>
<div style="display: flex; flex-direction: column; line-height: 1;">
<span style="font-family: 'Playfair Display', serif; font-weight: 800; font-size: 1.2rem; letter-spacing: -0.02em; color: inherit;">SkillForge</span>
</div>
</a>
<nav class="desktop-theater-nav">
<a class="nav-link-item" href="#tour-office" id="link-office">
<span class="nav-dot"></span><svg fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
</svg> Ruang Administrasi
                </a>
<a class="nav-link-item" href="#tour-business" id="link-business">
<span class="nav-dot"></span><svg fill="none" height="14" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="14">
<rect height="14" rx="2" ry="2" width="20" x="2" y="3"></rect>
<line x1="8" x2="16" y1="21" y2="21"></line>
<line x1="12" x2="12" y1="17" y2="21"></line>
</svg> Ruang Bisnis
                </a>
</nav>
<button class="sf-btn sf-btn-outline" id="headerCartBtn" style="padding: 8px 16px;">
<span style="font-size: 14px;">Keranjang</span>
<svg fill="none" height="18" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="18">
<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
<line x1="3" x2="21" y1="6" y2="6"></line>
<path d="M16 10a4 4 0 0 1-8 0"></path>
</svg>
<div class="cart-dot" id="cartDot"></div>
</button>
</div>
</header>
<section class="view-section active" id="view-home">
<div class="hero-museum-dark">
<div class="spotlight-cone"></div>
<div class="stage-light-pool"></div>
<div class="gold-dust-container">
<div class="gold-dust" style="left:20%; animation-delay:0s; animation-duration:15s;"></div>
<div class="gold-dust" style="left:50%; animation-delay:5s; animation-duration:18s;"></div>
<div class="gold-dust" style="left:80%; animation-delay:2s; animation-duration:14s;"></div>
</div>
<div class="hero-content-center reveal-on-scroll visible">
<div class="hero-pre-title" style="border-color: rgba(252, 211, 77, 0.3); color: #FCD34D;">
                    ★ LEMBAGA RESMI TERVERIFIKASI
                </div>
<h1 class="hero-title-dark">
                    Satu Akses Menguasai <br/>
<span class="text-gold-metallic">Administrasi &amp; Digital Marketing</span>.
                </h1>
<p class="hero-desc-dark">
                    Solusi lengkap untuk lolos seleksi administrasi kerja (CPNS/BUMN) dan membangun bisnis digital mandiri. Resmi, bersertifikat, dan tanpa biaya bulanan.
                </p>
<div style="display: flex; justify-content: center; gap: 20px;">
<button class="sf-btn btn-glow-gold" onclick="document.getElementById('next-view').scrollIntoView({behavior:'smooth'})">
                        BUKA PINTU AKSES ↓
                    </button>
<button class="sf-btn sf-btn-outline hero-btn-outline" onclick="document.getElementById('tour-office').scrollIntoView({behavior:'smooth'})">
                        LIHAT KOLEKSI
                    </button>
</div>
<div class="trust-bar-container" style="opacity: 1; transform: none;">
<span class="trust-label">RESMI &amp; DIAKUI PEMERINTAH:</span>
<div class="trust-logos">
<img alt="Kemnaker RI" class="trust-logo-img" src="https://upload.wikimedia.org/wikipedia/commons/9/98/Logo_Kementerian_Ketenagakerjaan_%282016%29.png" title="Lembaga Pelatihan Kerja Terdaftar (VIN)"/>
<img alt="Kemdikbud" class="trust-logo-img" src="https://upload.wikimedia.org/wikipedia/commons/e/eb/Logo-Tut-Wuri-Handayani-PNG-Warna.png" title="Satuan Pendidikan Nonformal Terakreditasi (NPSN)"/>
</div>
</div>
</div>
<div class="monolith-stage">
<div class="crystal-block">
<div class="c-face cf-back"></div>
<div class="crystal-content">
<div class="float-icon depth-back"><img alt="Word" src="https://upload.wikimedia.org/wikipedia/commons/e/e8/Microsoft_Office_Word_%282025%E2%80%93present%29.svg"/></div>
<div class="float-icon depth-mid"><img alt="Excel" src="https://upload.wikimedia.org/wikipedia/commons/6/60/Microsoft_Office_Excel_%282025%E2%80%93present%29.svg"/></div>
<div class="float-icon depth-back"><img alt="PPT" src="https://upload.wikimedia.org/wikipedia/commons/d/df/Microsoft_Office_PowerPoint_%282025%E2%80%93present%29.svg"/></div>
<div class="float-icon depth-front icon-centerpiece">
<svg fill="white" height="40" viewBox="0 0 24 24" width="40">
<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
</svg>
</div>
<div class="float-icon depth-back"><img alt="Shopee" src="https://upload.wikimedia.org/wikipedia/commons/0/0e/Shopee_logo.svg"/></div>
<div class="float-icon depth-mid"><img alt="TikTok" src="https://cdn.icon-icons.com/icons2/3041/PNG/512/tiktok_logo_icon_189233.png"/></div>
<div class="float-icon depth-back"><img alt="CapCut" src="https://upload.wikimedia.org/wikipedia/commons/1/1c/Capcut-icon.svg"/></div>
</div>
<div class="c-face cf-front">
<div class="glass-glare"></div>
<div class="corner-accent c-tl"></div>
<div class="corner-accent c-tr"></div>
<div class="corner-accent c-bl"></div>
<div class="corner-accent c-br"></div>
</div>
</div>
</div>
<div class="floor-shadow"></div>
<div class="hero-bottom-fade"></div>
</div>
<div class="section-pain" id="next-view" style="background-color: #Fdfcfc;">
<div class="sf-container">
<div class="section-header-center" style="max-width: 700px; margin: 0 auto 60px;">
<span class="sf-badge" style="background: transparent; border: 1px solid var(--danger); color: var(--danger); margin-bottom: 16px;">
                        ⚠️ REALITA LAPANGAN
                    </span>
<h2 class="sf-h2 serif-heading">
                        Hambatan Karir: <br/>Cara Lama yang Tidak Efektif.
                    </h2>
<p class="sf-p" style="font-size: 1rem;">
                        Di era kompetitif, skill tanpa bukti legal adalah sia-sia. Jangan biarkan dua hal ini menghambat potensi penghasilan Anda.
                    </p>
</div>
<div class="pain-grid">
<div class="archive-card reveal-on-scroll">
<div style="display:flex; justify-content: space-between; align-items: start;">
<div>
<h3 class="sf-h3" style="font-family: 'Playfair Display', serif !important; font-size: 1.5rem !important;">Gagal Administrasi</h3>
<div style="font-size: 0.75rem; font-weight:700; text-transform: uppercase; letter-spacing: 1px; color: var(--danger); margin-top: 4px;">RISIKO TINGGI</div>
</div>
<div class="archive-num">I</div>
</div>
<div style="margin-top: 24px; border-top: 1px solid #F5F5F4; padding-top: 20px;">
<p style="font-weight:600; color:var(--text-primary); margin-bottom:10px; font-size: 1rem;">
                                "Skill jago tapi sertifikat tidak valid? Otomatis gugur."
                            </p>
<ul style="color:var(--text-secondary); font-size:0.9rem; line-height:1.6; list-style:none; padding:0; margin-left: 0;">
<li style="margin-bottom: 8px; display: flex; gap: 10px;">
<span style="color: var(--danger);">✕</span> Verifikator CPNS/BUMN hanya mengakui sertifikat LKP resmi (VIN/NPSN).
                                </li>
<li style="display: flex; gap: 10px;">
<span style="color: var(--danger);">✕</span> Sertifikat seminar/bootcamp seringkali tidak memiliki kekuatan hukum di pemberkasan.
                                </li>
</ul>
</div>
</div>
<div class="archive-card reveal-on-scroll delay-100">
<div style="display:flex; justify-content: space-between; align-items: start;">
<div>
<h3 class="sf-h3" style="font-family: 'Playfair Display', serif !important; font-size: 1.5rem !important;">Pemborosan Budget</h3>
<div style="font-size: 0.75rem; font-weight:700; text-transform: uppercase; letter-spacing: 1px; color: var(--danger); margin-top: 4px;">BIAYA OPERASIONAL BENGKAK</div>
</div>
<div class="archive-num">II</div>
</div>
<div style="margin-top: 24px; border-top: 1px solid #F5F5F4; padding-top: 20px;">
<p style="font-weight:600; color:var(--text-primary); margin-bottom:10px; font-size: 1rem;">
                                "Keuntungan bisnis habis hanya untuk bayar vendor hal sepele."
                            </p>
<ul style="color:var(--text-secondary); font-size:0.9rem; line-height:1.6; list-style:none; padding:0; margin-left: 0;">
<li style="margin-bottom: 8px; display: flex; gap: 10px;">
<span style="color: var(--danger);">✕</span> Bayar jasa desain feed/video mahal, padahal bisa dikerjakan sendiri dalam 5 menit.
                                </li>
<li style="display: flex; gap: 10px;">
<span style="color: var(--danger);">✕</span> Tergantung pada orang lain membuat bisnis lambat bergerak.
                                </li>
</ul>
</div>
</div>
</div>
</div>
</div>
<div class="section-value">
<div class="sf-container">
<div class="section-header-center">
<span class="sf-badge badge-navy" style="margin-bottom: 16px;">SOLUSI TERINTEGRASI</span>
<h2 class="sf-h2 serif-heading">Standar Kompetensi Modern.</h2>
<p class="sf-p" style="max-width: 600px; margin: 0 auto;">
                        Kurikulum yang dirancang untuk satu tujuan: Memberi Anda daya tawar tinggi di dunia kerja dan bisnis.
                    </p>
</div>
<div class="value-grid">
<div class="method-card reveal-on-scroll">
<div class="method-num">01</div>
<h3 class="sf-h3">Legalitas Negara</h3>
<p class="sf-p" style="font-size: 0.95rem; margin-bottom: 0;">
<strong>Aman Seleksi CPNS &amp; BUMN.</strong> Sertifikat keluaran LKP resmi yang terdaftar di Kemdikbud (NPSN) &amp; Kemnaker (VIN). Dokumen Anda valid dan diakui verifikator.
                        </p>
</div>
<div class="method-card reveal-on-scroll delay-100">
<div class="method-num">02</div>
<h3 class="sf-h3">Kemandirian Digital</h3>
<p class="sf-p" style="font-size: 0.95rem; margin-bottom: 0;">
<strong>Hemat Jutaan Rupiah.</strong> Pangkas biaya vendor. Kuasai desain (Canva/Photoshop) dan editing video (CapCut) untuk membuat konten promosi bisnis Anda sendiri.
                        </p>
</div>
<div class="method-card reveal-on-scroll delay-200">
<div class="method-num">03</div>
<h3 class="sf-h3">Efisiensi Kerja</h3>
<p class="sf-p" style="font-size: 0.95rem; margin-bottom: 0;">
<strong>Kerja 10x Lebih Cepat.</strong> Bukan sekadar mengetik. Kuasai rumus Excel canggih, Mail Merge, dan AI tools untuk menyelesaikan tumpukan tugas administrasi dalam hitungan menit.
                        </p>
</div>
</div>
</div>
</div>
<div class="grand-theater-stage" id="theaterStage">
<div class="theater-backdrop">
<div class="theater-noise"></div>
<div class="theater-texture"></div>
<div class="theater-spotlight"></div>
</div>
<div class="tour-transparent-section office-zone" id="tour-office">
<div class="sf-container">
<div class="tour-split-layout">
<div class="tour-content">
<h2 class="sf-h2" style="color:white !important;">Masteri Administrasi Perkantoran.</h2>
<p class="sf-p" style="margin-bottom: 20px; color:rgba(255,255,255,0.8) !important;">
                                Program pendidikan vokasi standar LKP. Kuasai Microsoft Office (Word, Excel, PPT) untuk kebutuhan administrasi kerja harian, skripsi, hingga tes CPNS &amp; BUMN.
                            </p>
<div class="impact-metrics" style="border-color: rgba(255,255,255,0.1);">
<div class="metric-item">
<span class="metric-val" style="color:white;">124.272+</span>
<span class="metric-label" style="color:rgba(255,255,255,0.6);">Alumni Terdaftar</span>
</div>
<div class="metric-item">
<span class="metric-val" style="color:white;">4.9/5.0</span>
<span class="metric-label" style="color:rgba(255,255,255,0.6);">Rating Kepuasan</span>
</div>
<div class="metric-item">
<span class="metric-val" style="color:white;">LKP Resmi</span>
<span class="metric-label" style="color:rgba(255,255,255,0.6);">Status Lembaga</span>
</div>
</div>
<div class="museum-frame" onclick="openLightbox('https://kelas.kursusdigital.id/wp-content/uploads/2025/08/Contoh-Sertifikat-Kursus-Office-LKP-Ifan-Jaya-e1756202925732-600x425.jpg')" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); margin-bottom: 60px;">
<img alt="Sertifikat LKP" class="artifact-img" src="https://kelas.kursusdigital.id/wp-content/uploads/2025/08/Contoh-Sertifikat-Kursus-Office-LKP-Ifan-Jaya-e1756202925732-600x425.jpg"/>
