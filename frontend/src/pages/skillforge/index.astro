</div>
</div>
</div>
</div>
<div class="tech-specs" style="background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.1);">
<div class="spec-header" style="color:rgba(255,255,255,0.7);">
<svg fill="none" height="16" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="16">
<circle cx="12" cy="12" r="10"></circle>
<path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
<line x1="12" x2="12.01" y1="17" y2="17"></line>
</svg>
                                    PROTOKOL PELAKSANAAN
                                </div>
<ul class="spec-list" style="margin-left: 0;">
<li class="spec-item" style="border-color:rgba(255,255,255,0.1);">
