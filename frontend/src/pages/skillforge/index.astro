<img alt="Logo Ifan Jaya" class="lkp-logo-inline" src="https://kursusdigital.id/wp-content/uploads/2024/04/avatar_user_99364_1713687583-200x200.png"/>
<div style="font-weight:800; color:#1e293b; font-size:1.1rem; letter-spacing:-0.5px;">LKP IFAN JAYA</div>
</div>
</div>
<div style="text-align:right;">
<img alt="Tut Wuri" src="https://upload.wikimedia.org/wikipedia/commons/e/eb/Logo-Tut-Wuri-Handayani-PNG-Warna.png" width="40"/>
