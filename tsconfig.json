{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/types/*"],
      "@scripts/*": ["scripts/*"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "api-worker",
    "frontend"
  ]
}
